# Application
SPRING_APPLICATION_NAME=banquito-file-reception-service
SPRING_CONFIG_IMPORT=optional:file:.env[.properties]
SERVER_PORT=8084

# File reception rules
APP_DUPLICATE_WINDOW_DAYS=30
APP_FILE_DELIMITER=,
APP_CUTOFF_HOUR=18
APP_PAYMENT_LINE_TRANSPORT=rabbitmq
APP_RABBIT_ENABLED=true
APP_RABBIT_QUEUE=payment.lines.queue
APP_GRPC_HOST=localhost
APP_GRPC_PORT=9090
APP_GRPC_DEADLINE_SECONDS=10

# Core Banking / holiday calendar
CORE_BASE_URL=http://localhost:8080
CORE_HOLIDAY_ENDPOINT=/api/v1/holidays/is-business-day
CORE_ACCOUNT_VALIDATION_ENDPOINT=/api/v1/accounts/validate
CORE_MASS_PAYMENT_SERVICE_ENDPOINT=/api/v1/customers/mass-payments/active
APP_CORE_VALIDATION_ENABLED=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=file_reception
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123
POSTGRES_DRIVER=org.postgresql.Driver
POSTGRES_AUTO_CREATE_DB=true
POSTGRES_MAINTENANCE_DB=postgres
JPA_DDL_AUTO=update
JPA_OPEN_IN_VIEW=false
JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=file_reception
# Use MONGO_URI when MongoDB needs user/password, replicaSet, authSource, or K8s DNS.
MONGO_URI=mongodb://localhost:27017/file_reception

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Multipart limits
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# Actuator
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health
MANAGEMENT_HEALTH_PROBES_ENABLED=true
MANAGEMENT_HEALTH_RABBIT_ENABLED=false
