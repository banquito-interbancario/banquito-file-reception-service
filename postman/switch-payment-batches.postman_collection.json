{
  "info": {
    "_postman_id": "7e5a0765-f5fb-4a5d-9a02-6047f15c0c1f",
    "name": "Switch Payment Batches",
    "description": "Pruebas RF-01/RF-02 para POST /api/v1/payments/batches.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8084"
    },
    {
      "key": "clientRuc",
      "value": "0912345678"
    },
    {
      "key": "serviceType",
      "value": "NOMINA"
    }
  ],
  "item": [
    {
      "name": "Health - Actuator",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/actuator/health",
          "host": ["{{baseUrl}}"],
          "path": ["actuator", "health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Health UP', function () { pm.expect(pm.response.json().status).to.eql('UP'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Batch valido - 202 RECEIVED",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "../test-files/batch-valid.csv"
            },
            {
              "key": "serviceType",
              "value": "{{serviceType}}",
              "type": "text"
            },
            {
              "key": "clientRuc",
              "value": "{{clientRuc}}",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/payments/batches",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "payments", "batches"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 202 Accepted', function () { pm.response.to.have.status(202); });",
              "pm.test('Status RECEIVED', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.batch_id || body.batchId).to.exist;",
              "  pm.expect(body.status).to.eql('RECEIVED');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Batch duplicado - 409",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
